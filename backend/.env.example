# Server
PORT=3000
NODE_ENV=development

# CORS
CORS_ORIGINS=https://your-frontend.vercel.app

DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres
DATABASE_SSL=true

# Redis
REDIS_URL=redis://redis:6379

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Transaction tuning
TRANSACTION_MAX_ATTEMPTS=4
TRANSACTION_TIMEOUT_MS=8000
TRANSACTION_BACKOFF_BASE_MS=500

# Rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Mock provider
MOCK_LATENCY_MS_MIN=100
MOCK_LATENCY_MS_MAX=1200
MOCK_TIMEOUT_RATE=0.1
MOCK_5XX_RATE=0.15
MOCK_429_RATE=0.1
MOCK_4XX_RATE=0.05

# Reaper
STALLED_SWEEP_MS=30000
STALLED_THRESHOLD_MS=60000
